{
  "manifest_version": 3,
  "name": "NYC Apartment Evaluator",
  "version": "2.0.0",
  "description": "Automatically evaluate NYC apartments based on commute, transit, and amenities (Standalone)",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://maps.googleapis.com/*",
    "https://*.streeteasy.com/*",
    "https://*.zillow.com/*",
    "https://*.apartments.com/*",
    "https://*.renthop.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.streeteasy.com/*",
        "https://*.zillow.com/*",
        "https://*.apartments.com/*",
        "https://*.renthop.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["data/subway_stations.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
